{
  "name": "route-optimization-service",
  "version": "1.0.0",
  "description": "EMEC Route Optimization Service (Node.js 20 + Express + OR-Tools Python)",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && prisma generate",
    "start": "node dist/index.js",
