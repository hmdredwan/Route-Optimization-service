// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model OptimizationRequest {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  driver_id           String
  driver_name         String
  driver_start_lat    Float     // ← added
  driver_start_lng    Float     // ← added
  stops_input         Json      @db.JsonB
  optimized_sequence  Json?     @db.JsonB
  legs                Json?     @db.JsonB
  route_geometry      Json?     @db.JsonB
  total_distance_m    Int?
  total_duration_s    Int?
  solver_time_ms      Int?
  time_limit_ms       Int?
  created_at          DateTime  @default(now()) @db.Timestamptz(6)

  @@map("optimization_requests")
}